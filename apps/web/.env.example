# ─── Supabase ──────────────────────────────────────────────────────────────────
# Obtené estos valores en: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://reunio.app
# Secreto para firmar tokens de gestión de turnos (min 32 chars aleatorios)
JWT_SECRET=

# ─── Crons (Vercel cron jobs) ──────────────────────────────────────────────────
# Vercel genera este header automáticamente. Definilo también en env para validar.
CRON_SECRET=

# ─── Mercado Pago (señas de clientes) ─────────────────────────────────────────
# https://www.mercadopago.com.ar/developers/es/docs/checkout-pro/prerequisites
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_PUBLIC_KEY=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=

# ─── Stripe (suscripciones SaaS) ──────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# IDs de productos en Stripe (crear en dashboard o via CLI)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# ─── WhatsApp / 360dialog ──────────────────────────────────────────────────────
# https://hub.360dialog.com
WHATSAPP_API_TOKEN=
WHATSAPP_API_URL=https://waba.360dialog.io/v1
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_SECRET=

# ─── Resend (emails transaccionales) ──────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── Sentry (monitoreo de errores) ────────────────────────────────────────────
# https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=

# ─── PostHog (analíticas) ─────────────────────────────────────────────────────
# https://app.posthog.com → Project Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
